{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Run Unittest (tests.*)",
            "type": "debugpy",
            "request": "launch",
            "module": "unittest",
            "cwd": "${workspaceFolder}/mnt/app",
            "args": [
                "tests.model.utils.transformer"
            ],
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Python: Unittest Discover All",
            "type": "debugpy",
            "request": "launch",
            "module": "unittest",
            "cwd": "${workspaceFolder}/mnt/app",
            "args": [
                "discover",
                "-s", "tests",
                "-t", "${workspaceFolder}/mnt/app",
                "-p", "*.py"
            ],
            "console": "integratedTerminal",
            "justMyCode": false
        }
    ]
}